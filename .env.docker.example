# ===========================================================
# ZeroX Docker Environment Variables
# Copy this file to .env and fill in the values
# ===========================================================

# ---- MySQL Database ----
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=computer_shop
MYSQL_USER=zerox
MYSQL_PASSWORD=zerox123

# ---- JWT ----
JWT_SECRET_KEY=change_me_in_production_use_a_long_random_string_at_least_256_bits
JWT_EXPIRATION=86400000

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here

# ---- SendGrid (Email) ----
SENDGRID_API_KEY=

# ---- Frontend URL (used by backend for CORS / email links) ----
VITE_ENDPOINT=http://localhost:3000
